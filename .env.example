# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding API (base URL; client POSTs to .../v1/embeddings)
EMBEDDING_URL=http://localhost:8001
# curl: -H "X-Internal-Key: …"
EMBEDDING_INTERNAL_KEY=

EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_SIZE=1024

# Collection suffix for query_chunks: dev | qa | prod
ENV=dev

TOP_K_DENSE=20
RRF_K=60

# Inference / chat API (app.rag_answer; not required for `import app`)
INFERENCE_URL=http://localhost:30080
INFERENCE_MODEL=Qwen/Qwen2.5-7B-Instruct
# INFERENCE_MAX_TOKENS=512

GRAFANA_CLOUD_URL=https://logs-prod-XXX.grafana.net
GRAFANA_CLOUD_USER=your-stack-user-id
GRAFANA_CLOUD_API_KEY=your-loki-write-token
