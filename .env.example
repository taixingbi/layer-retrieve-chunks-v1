# Qdrant
QDRANT_URL=http://192.168.86.179:6333
QDRANT_API_KEY=

# Embedding API (base URL; client POSTs to .../v1/embeddings)
EMBEDDING_URL=http://192.168.86.179:30181
EMBEDDING_MODEL=BAAI/bge-m3
VECTOR_SIZE=1024

# Collection suffix for query_chunks: dev | qa | prod
ENV=dev

TOP_K_DENSE=20
RRF_K=60

# Inference / chat API (app.rag_answer; not required for `import app`)
INFERENCE_URL=http://192.168.86.179:30080
INFERENCE_MODEL=Qwen/Qwen2.5-7B-Instruct
# INFERENCE_MAX_TOKENS=512

# Reranker API (base URL; client POSTs to .../v1/rerank)
RERANK_URL=http://192.168.86.179:30182
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Fused-retrieval candidates sent to reranker (document count; typically matches k_max ~50)
RERANK_TOP_N=50
# Rerank API top_n: ranked rows kept after rerank (must be >= FINAL_CONTEXT_TOP_K)
RERANK_RETURN_TOP_K=25
# After rerank, append up to N raw RRF chunks not in rerank output (hedge rerank recall loss)
RETRIEVE_FALLBACK_N=8
# Max passages in one chat prompt; NOT_FOUND widen stops at this cap
FINAL_CONTEXT_TOP_K=12

